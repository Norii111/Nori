{
  "manifest_version": 3,
  "name": "Command Userscript Manager",
  "version": "1.0.0",
  "description": "Install userscripts directly from my Command Center.",

  "permissions": [
    "storage",
    "userScripts"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://YOUR-USERNAME.github.io/YOUR-REPOSITORY/*"
      ],
      "js": [
        "content-script.js"
      ]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
